    },
    {
      "path": "/api/cron",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron",
      "schedule": "0 18 * * *"
    }
  ]
}
